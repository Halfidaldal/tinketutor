rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userMatches(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function docOwnedByCurrentUser(doc) {
      return signedIn() && doc.user_id == request.auth.uid;
    }

    function notebookOwnedByCurrentUser(notebookId) {
      return signedIn()
        && exists(/databases/$(database)/documents/notebooks/$(notebookId))
        && get(/databases/$(database)/documents/notebooks/$(notebookId)).data.user_id == request.auth.uid;
    }

    function sourceOwnedByCurrentUser(sourceId) {
      return signedIn()
        && exists(/databases/$(database)/documents/sources/$(sourceId))
        && get(/databases/$(database)/documents/sources/$(sourceId)).data.user_id == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if userMatches(userId);
    }

    match /notebooks/{notebookId} {
      allow create: if docOwnedByCurrentUser(request.resource.data);
      allow read, update, delete: if docOwnedByCurrentUser(resource.data);

      match /{document=**} {
        allow read, write: if notebookOwnedByCurrentUser(notebookId);
      }
    }

    match /sources/{sourceId} {
      allow create: if docOwnedByCurrentUser(request.resource.data);
      allow read, update, delete: if docOwnedByCurrentUser(resource.data);

      match /{document=**} {
        allow read, write: if sourceOwnedByCurrentUser(sourceId);
      }
    }

    match /jobs/{jobId} {
      allow create: if docOwnedByCurrentUser(request.resource.data);
      allow read, update, delete: if docOwnedByCurrentUser(resource.data);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
