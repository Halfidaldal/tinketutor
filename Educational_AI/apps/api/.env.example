ENVIRONMENT=local
# JSON array or comma-separated list. In deployed environments, set only the
# exact frontend origins that should be allowed to call the API.
CORS_ORIGINS=["http://localhost:3000"]

# Firebase runtime
FIREBASE_PROJECT_ID=synthesis-studio-dev
FIREBASE_STORAGE_BUCKET=synthesis-studio-dev.appspot.com
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
STORAGE_EMULATOR_HOST=127.0.0.1:9199

# Local runtime seams
OBJECT_STORE_BACKEND=firebase
PARSER_BACKEND=local
LOCAL_STORAGE_DIR=.local_storage

# Provider configuration
LLM_PROVIDER=google_vertex
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=europe-west1
GEMINI_MODEL=gemini-1.5-pro
EMBEDDING_MODEL=text-embedding-004
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Retrieval toggles
RETRIEVAL_ENABLE_VECTOR=false
